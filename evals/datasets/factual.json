{
  "name": "factual_accuracy",
  "description": "Verifies that Joseph responds with correct CV data",
  "tests": [
    {
      "id": "exp-years",
      "description": "Should mention significant years of experience or start date",
      "input": "How many years of experience do you have?",
      "lang": "en",
      "assertions": [
        { "type": "contains_any", "values": ["10", "2015", "2016", "audio", "AV"] },
        { "type": "not_contains", "value": "I don't know" }
      ]
    },
    {
      "id": "project-name",
      "description": "Should mention a key project name: OpenClaw or The Skate Workshop",
      "input": "What are your main projects?",
      "lang": "en",
      "assertions": [
        { "type": "contains_any", "values": ["OpenClaw", "Skate Workshop"] }
      ]
    },
    {
      "id": "location",
      "description": "Should mention Escondido or San Diego",
      "input": "Where are you based?",
      "lang": "en",
      "assertions": [
        { "type": "contains_any", "values": ["Escondido", "San Diego", "California"] }
      ]
    },
    {
      "id": "current-role",
      "description": "Should mention Quadient as current role",
      "input": "Where do you currently work?",
      "lang": "en",
      "assertions": [
        { "type": "contains_any", "values": ["Quadient", "quadient"] }
      ]
    },
    {
      "id": "business-name",
      "description": "Should mention Joe's Tech Solutions",
      "input": "Have you had your own business?",
      "lang": "en",
      "assertions": [
        { "type": "contains_any", "values": ["Joe's Tech Solutions", "Joe's Tech"] }
      ]
    },
    {
      "id": "target-roles",
      "description": "Should mention target roles",
      "input": "What roles are you interested in?",
      "lang": "en",
      "assertions": [
        { "type": "contains_any", "values": ["AI Developer", "DevOps", "SRE", "Embedded", "Robotics"] }
      ]
    },
    {
      "id": "repo-public",
      "description": "Should confirm the portfolio repo is public on GitHub",
      "input": "Is the code for cv-joseph.vercel.app on GitHub?",
      "lang": "en",
      "assertions": [
        { "type": "contains_any", "values": ["public", "open", "GitHub"] },
        { "type": "contains_any", "values": ["joblas", "cv-santiago"] },
        { "type": "not_contains", "value": "private" }
      ]
    },
    {
      "id": "model-version",
      "description": "Should say Claude Sonnet 4.5, not 3.5 Sonnet",
      "input": "What AI model do you use?",
      "lang": "en",
      "assertions": [
        { "type": "contains_any", "values": ["Sonnet 4.5", "sonnet-4-5", "Claude Sonnet 4"] },
        { "type": "not_contains", "value": "3.5 Sonnet" },
        { "type": "not_contains", "value": "Sonnet 3.5" }
      ]
    }
  ]
}
