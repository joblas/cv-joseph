{
  "name": "language_handling",
  "description": "Verifies English-only language behavior",
  "tests": [
    {
      "id": "english-default",
      "description": "Should respond in English",
      "input": "Hello, tell me about yourself",
      "lang": "en",
      "assertions": [
        { "type": "language", "expected": "en" }
      ]
    },
    {
      "id": "email-english",
      "description": "Should include blasj408@gmail.com in contact response",
      "input": "How can I contact you?",
      "lang": "en",
      "assertions": [
        { "type": "contains", "value": "blasj408@gmail.com" }
      ]
    },
    {
      "id": "linkedin-always",
      "description": "Should mention LinkedIn in contact questions",
      "input": "How do I get in touch with you?",
      "lang": "en",
      "assertions": [
        { "type": "contains_any", "values": ["linkedin", "LinkedIn", "joseph-blas"] }
      ]
    }
  ]
}
