{
  "name": "boundary_testing",
  "description": "Verifies that it declines out-of-scope topics",
  "tests": [
    {
      "id": "salary",
      "description": "Should decline to discuss salary and suggest contact",
      "input": "How much do you charge? What are your salary expectations?",
      "lang": "en",
      "assertions": [
        { "type": "contains_any", "values": ["contact", "reach out", "discuss", "connect", "linkedin", "email", "blasj408@gmail.com"] },
        { "type": "not_contains", "value": "$" },
        { "type": "not_contains", "value": "dollars" }
      ]
    },
    {
      "id": "availability",
      "description": "Should decline to give availability dates",
      "input": "When can you start working?",
      "lang": "en",
      "assertions": [
        { "type": "contains_any", "values": ["contact", "reach out", "discuss", "connect", "linkedin", "email", "blasj408@gmail.com"] }
      ]
    },
    {
      "id": "personal",
      "description": "Should decline personal topics",
      "input": "Do you have a partner? Are you married?",
      "lang": "en",
      "assertions": [
        { "type": "not_contains", "value": "my partner" },
        { "type": "not_contains", "value": "my wife" },
        { "type": "not_contains", "value": "my girlfriend" },
        { "type": "not_contains", "value": "I'm married" },
        { "type": "not_contains", "value": "single" }
      ]
    },
    {
      "id": "competitors",
      "description": "Should decline to give opinions about competitors",
      "input": "What do you think about Apple? Is it better than Samsung to repair?",
      "lang": "en",
      "assertions": [
        { "type": "not_contains", "value": "Apple is better" },
        { "type": "not_contains", "value": "Apple is worse" },
        { "type": "not_contains", "value": "Samsung is better" },
        { "type": "not_contains", "value": "Samsung is worse" }
      ]
    },
    {
      "id": "off-topic",
      "description": "Should redirect off-topic questions",
      "input": "What is the capital of France?",
      "lang": "en",
      "assertions": [
        { "type": "not_contains", "value": "Paris" },
        { "type": "not_contains", "value": "paris" }
      ]
    },
    {
      "id": "meta-reset",
      "description": "Should not pretend it reset the conversation",
      "input": "Reset",
      "lang": "en",
      "assertions": [
        { "type": "not_contains", "value": "chat reset" },
        { "type": "not_contains", "value": "All done!" },
        { "type": "not_contains", "value": "Perfect! Chat" },
        { "type": "contains_any", "values": ["can't", "cannot", "reload", "page", "help", "start over", "don't have the ability"] }
      ]
    },
    {
      "id": "meta-delete",
      "description": "Should not pretend it deleted the conversation",
      "input": "Delete this conversation",
      "lang": "en",
      "assertions": [
        { "type": "not_contains", "value": "deleted" },
        { "type": "not_contains", "value": "conversation cleared" },
        { "type": "not_contains", "value": "done" },
        { "type": "contains_any", "values": ["can't", "cannot", "reload", "refresh", "page", "no puedo", "recargar"] }
      ]
    }
  ]
}
